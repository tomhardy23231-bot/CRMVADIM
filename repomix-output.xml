} from 'lucide-react';
import { PageId } from '@/lib/crm-types';
import { MOCK_CURRENT_USER } from '@/lib/mock-data';

// ============================================================
// Navigation structure — matches keyCRM sidebar layout
// ============================================================

interface NavGroup {
  label: string;
  icon: React.ReactNode;
  page: PageId;
}

const SALES_GROUP: NavGroup[] = [
  { label: 'Воронки', icon: <LayoutDashboard size={18} />, page: 'dashboard' },
  { label: 'Продажи', icon: <ShoppingCart size={18} />, page: 'orders' },
  { label: 'Заказы', icon: <ClipboardList size={18} />, page: 'orders' },
];

const MAIN_NAV: NavGroup[] = [
  { label: 'Списки заказов', icon: <ClipboardList size={18} />, page: 'orders' },
  { label: 'Покупатели', icon: <Users size={18} />, page: 'orders' },
  { label: 'Компании', icon: <Building2 size={18} />, page: 'orders' },
  { label: 'Производство', icon: <Factory size={18} />, page: 'dashboard' },
  { label: 'История звонков', icon: <Phone size={18} />, page: 'orders' },
];

const FINANCE_NAV: NavGroup[] = [
  { label: 'Журнал платежей', icon: <DollarSign size={18} />, page: 'finance' },
  { label: 'Платежный календарь', icon: <CalendarDays size={18} />, page: 'calendar' },
];

interface SidebarProps {
  currentPage: PageId;
  onNavigate: (page: PageId) => void;
  collapsed: boolean;
  onToggleCollapse: () => void;
}

export default function Sidebar({ currentPage, onNavigate, collapsed }: SidebarProps) {
  const [salesExpanded, setSalesExpanded] = useState(true);
  const user = MOCK_CURRENT_USER;

  return (
    <aside
      className={`flex flex-col h-screen bg-[#2A5CAA] text-white shrink-0 transition-all duration-300 ${
        collapsed ? 'w-[64px]' : 'w-[240px]'
      }`}
    >
      {/* Logo area */}
      <div className="flex items-center gap-3 px-4 h-14 border-b border-white/10 shrink-0">
        <div className="w-8 h-8 rounded-lg bg-white/20 flex items-center justify-center font-bold text-sm shrink-0">
          W
        </div>
        {!collapsed && (
          <span className="font-semibold text-sm tracking-wide">WEST WOOD</span>
        )}
      </div>

      {/* Scrollable nav */}
      <nav className="flex-1 overflow-y-auto crm-scroll py-3 px-2 space-y-1">
        {/* Sales group */}
        <div className="mb-2">
          {!collapsed && (
            <button
              onClick={() => setSalesExpanded(!salesExpanded)}
              className="flex items-center gap-2 w-full px-3 py-2 text-white/90 hover:bg-white/10 rounded-lg text-xs font-bold uppercase tracking-wider transition-colors"
            >
              <ShoppingCart size={14} />
              <span className="flex-1 text-left">Продажи</span>
              {salesExpanded ? <ChevronDown size={14} /> : <ChevronRight size={14} />}
            </button>
          )}
          {salesExpanded && (
            <div className="ml-1 space-y-0.5 mt-1 animate-fade-in">
              {SALES_GROUP.map((item) => (
                <div
                  key={item.label}
                  onClick={() => onNavigate(item.page)}
                  className={`sidebar-nav-item ${currentPage === item.page ? 'active' : ''}`}
                >
                  {item.icon}
                  {!collapsed && <span>{item.label}</span>}
                </div>
              ))}
            </div>
          )}
        </div>

        {/* Divider */}
        <div className="border-t border-white/10 my-2" />

        {/* Main navigation */}
        {MAIN_NAV.map((item) => (
          <div
            key={item.label}
            onClick={() => onNavigate(item.page)}
            className={`sidebar-nav-item ${currentPage === item.page ? 'active' : ''}`}
            title={collapsed ? item.label : undefined}
          >
            {item.icon}
            {!collapsed && <span>{item.label}</span>}
          </div>
        ))}

        {/* Divider */}
        <div className="border-t border-white/10 my-2" />

        {/* Finance group */}
        {!collapsed && (
          <div className="px-3 py-2 text-[10px] font-bold uppercase tracking-widest text-white/40">
            Финансы
          </div>
        )}
        {FINANCE_NAV.map((item) => (
          <div
            key={item.label}
            onClick={() => onNavigate(item.page)}
            className={`sidebar-nav-item ${currentPage === item.page ? 'active' : ''}`}
            title={collapsed ? item.label : undefined}
          >
            {item.icon}
            {!collapsed && <span>{item.label}</span>}
          </div>
        ))}
      </nav>

      {/* Bottom section */}
      <div className="border-t border-white/10 px-2 py-3 space-y-1 shrink-0">
        {/* Search */}
        {!collapsed && (
          <div className="relative mb-2">
            <Search size={14} className="absolute left-3 top-1/2 -translate-y-1/2 text-white/50" />
            <input
              type="text"
              placeholder="Поиск..."
              className="w-full bg-white/10 text-white placeholder-white/40 text-xs rounded-lg pl-9 pr-3 py-2 outline-none focus:bg-white/15 transition-colors"
            />
          </div>
        )}

        <div className="flex items-center gap-2 px-2">
          {/* Notifications */}
          <button className="relative p-2 rounded-lg hover:bg-white/10 transition-colors" title="Уведомления">
            <Bell size={18} className="text-white/70" />
            <span className="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full" />
          </button>

          {/* Help */}
          <button className="p-2 rounded-lg hover:bg-white/10 transition-colors" title="Помощь">
            <HelpCircle size={18} className="text-white/70" />
          </button>

          {/* Settings */}
          <button
            onClick={() => onNavigate('settings')}
            className="p-2 rounded-lg hover:bg-white/10 transition-colors"
            title="Настройки"
          >
            <Settings size={18} className="text-white/70" />
          </button>
        </div>

        {/* User profile */}
        <div className="flex items-center gap-3 px-2 mt-2 py-2 rounded-lg hover:bg-white/10 transition-colors cursor-pointer">
          <div className="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center text-xs font-bold shrink-0">
            {user.firstName[0]}{user.lastName[0]}
          </div>
          {!collapsed && (
            <div className="flex-1 min-w-0">
              <div className="text-sm font-medium truncate">{user.firstName} {user.lastName}</div>
              <div className="text-[11px] text-white/50">{user.role}</div>
            </div>
          )}
        </div>
      </div>
    </aside>
  );
}
