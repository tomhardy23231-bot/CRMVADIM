<file path="src/app/page.tsx">
'use client';

import React, { useState, useMemo } from 'react';
import { PageId } from '@/lib/crm-types';
import { MOCK_ORDERS } from '@/lib/mock-data';
import Sidebar from '@/components/crm/Sidebar';
import Header from '@/components/crm/Header';
import Dashboard from '@/components/crm/Dashboard';
import OrdersList from '@/components/crm/OrdersList';
import OrderDetail from '@/components/crm/OrderDetail';
import Settings from '@/components/crm/Settings';
import Finance from '@/components/crm/Finance';
import PaymentCalendarPage from '@/components/crm/PaymentCalendar';
import MobileSidebar from '@/components/crm/MobileSidebar';

export default function Home() {
  const [currentPage, setCurrentPage] = useState<PageId>('dashboard');
  const [selectedOrderId, setSelectedOrderId] = useState<string | null>(null);
  const [sidebarCollapsed, setSidebarCollapsed] = useState(false);

  const handleNavigate = (page: PageId) => {
    setCurrentPage(page);
    setSelectedOrderId(null);
  };

  const handleSelectOrder = (orderId: string) => {
    setSelectedOrderId(orderId);
    setCurrentPage('order-detail');
  };

  const handleBack = () => {
    setSelectedOrderId(null);
    setCurrentPage('orders');
  };

  const selectedOrder = useMemo(
    () => MOCK_ORDERS.find(o => o.id === selectedOrderId),
    [selectedOrderId]
  );

  const pageTitle = useMemo(() => {
    if (currentPage === 'order-detail' && selectedOrder) {
      return `#${selectedOrder.id} ${selectedOrder.title}`;
    }
    return '';
  }, [currentPage, selectedOrder]);

  const breadcrumbs = useMemo(() => {
    if (currentPage === 'order-detail' && selectedOrder) {
      return ['Продажи', `#${selectedOrder.id} ${selectedOrder.title}`];
    }
    return [];
  }, [currentPage, selectedOrder]);

  const renderContent = () => {
    switch (currentPage) {
      case 'dashboard':
        return <Dashboard onNavigate={handleNavigate} onSelectOrder={handleSelectOrder} />;
      case 'orders':
        return <OrdersList onNavigate={handleNavigate} onSelectOrder={handleSelectOrder} />;
      case 'order-detail':
        return selectedOrderId ? (
          <OrderDetail orderId={selectedOrderId} onNavigate={handleNavigate} onBack={handleBack} />
        ) : (
          <OrdersList onNavigate={handleNavigate} onSelectOrder={handleSelectOrder} />
        );
      case 'calendar':
        return <PaymentCalendarPage />;
      case 'settings':
        return <Settings onNavigate={handleNavigate as any} />;
      case 'finance':
        return <Finance />;
      default:
        return <Dashboard onNavigate={handleNavigate} onSelectOrder={handleSelectOrder} />;
    }
  };

  return (
    <div className="h-screen flex overflow-hidden bg-white">
      {/* Desktop sidebar */}
      <div className="hidden lg:block">
        <Sidebar
          currentPage={currentPage}
          onNavigate={handleNavigate}
          collapsed={sidebarCollapsed}
          onToggleCollapse={() => setSidebarCollapsed(!sidebarCollapsed)}
        />
      </div>

      {/* Main content area */}
      <div className="flex-1 flex flex-col overflow-hidden min-w-0">
        {/* Header */}
        <Header
          currentPage={currentPage}
          onNavigate={handleNavigate}
          onToggleSidebar={() => {}}
          pageTitle={pageTitle}
          breadcrumbs={breadcrumbs}
        />

        {/* Page content */}
        {renderContent()}
      </div>

      {/* Mobile sidebar overlay */}
      <div className="lg:hidden fixed top-0 left-0 z-50">
        <MobileSidebar currentPage={currentPage} onNavigate={handleNavigate}>
          <button className="fixed top-3 left-3 z-[60] p-2 rounded-lg bg-white shadow-md hover:bg-gray-50 transition-colors lg:hidden">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
              <line x1="4" x2="20" y1="12" y2="12" />
              <line x1="4" x2="20" y1="6" y2="6" />
              <line x1="4" x2="20" y1="18" y2="18" />
            </svg>
          </button>
        </MobileSidebar>
      </div>
    </div>
  );
}
</file>

<file path="src/components/crm/Dashboard.tsx">
'use client';

import React from 'react';
import {
  TrendingUp,
  TrendingDown,
  ShoppingCart,
  DollarSign,
  CreditCard,
  Receipt,
  XCircle,
  BarChart3,
  ArrowUpRight,
  Clock,
  CheckCircle2,
  AlertTriangle,
  Truck,
  FileText,
} from 'lucide-react';
import { MOCK_ORDERS, MOCK_DASHBOARD_METRICS } from '@/lib/mock-data';
import { formatUAH, formatNumber, formatPercent, getRelativeDate } from '@/lib/crm-utils';
import { DashboardMetrics, Order, PageId } from '@/lib/crm-types';
import {
  BarChart,
  Bar,
  XAxis,
  YAxis,
  CartesianGrid,
  Tooltip,
  ResponsiveContainer,
  PieChart,
  Pie,
  Cell,
  LineChart,
  Line,
  Area,
  AreaChart,
} from 'recharts';

interface DashboardProps {
  onNavigate: (page: PageId) => void;
  onSelectOrder: (orderId: string) => void;
}

// ============================================================
// Metric Card Component
// ============================================================
function MetricCard({
  title,
  value,
  change,
  icon,
  prefix = '',
  suffix = '',
}: {
  title: string;
  value: string | number;
  change: number;
  icon: React.ReactNode;
  prefix?: string;
  suffix?: string;
}) {
  const isPositive = change >= 0;
  const isNeutral = Math.abs(change) === 0;

  return (
    <div className="bg-white rounded-xl p-4 border border-[#E2E8F0] metric-card">
      <div className="flex items-start justify-between">
        <div className="space-y-1">
          <p className="text-xs font-medium text-[#64748B] uppercase tracking-wider">{title}</p>
          <p className="text-xl font-bold text-gray-900">
            {prefix}{typeof value === 'number' ? formatNumber(value) : value}{suffix}
          </p>
        </div>
        <div className="p-2 rounded-lg bg-[#F5F6FA] text-[#2A5CAA]">
          {icon}
        </div>
      </div>
      <div className="flex items-center gap-1.5 mt-3">
        {isNeutral ? (
          <span className="text-xs text-gray-400">— без изменений</span>
        ) : (
          <>
            {isPositive ? (
              <TrendingUp size={14} className="text-emerald-500" />
            ) : (
              <TrendingDown size={14} className="text-red-500" />
            )}
            <span className={`text-xs font-medium ${isPositive ? 'text-emerald-600' : 'text-red-600'}`}>
              {formatPercent(change)}
            </span>
            <span className="text-xs text-gray-400">за период</span>
          </>
        )}
      </div>
    </div>
  );
}

// ============================================================
// Funnel data for PieChart
// ============================================================
function getFunnelData(orders: Order[]) {
  const statuses = ['NEW', 'IN_PRODUCTION', 'ASSEMBLY', 'SHIPPED', 'COMPLETED'] as const;
  const colors = ['#10B981', '#F59E0B', '#3B82F6', '#8B5CF6', '#6B7280'];
  return statuses
    .map((s, i) => ({
      name: s === 'NEW' ? 'Новые' : s === 'IN_PRODUCTION' ? 'В производстве' : s === 'ASSEMBLY' ? 'Сборка' : s === 'SHIPPED' ? 'Отгружены' : 'Выполнены',
      value: orders.filter(o => o.status === s).length,
      color: colors[i],
    }))
    .filter(d => d.value > 0);
}

// ============================================================
// Revenue chart mock data
// ============================================================
const revenueChartData = Array.from({ length: 12 }, (_, i) => ({
  month: ['Янв', 'Фев', 'Мар', 'Апр', 'Май', 'Июн', 'Июл', 'Авг', 'Сен', 'Окт', 'Ноя', 'Дек'][i],
  orders: Math.floor(Math.random() * 20) + 5,
  revenue: Math.floor(Math.random() * 150000) + 50000,
}));

// ============================================================
// Dashboard Component
// ============================================================
export default function Dashboard({ onNavigate, onSelectOrder }: DashboardProps) {
  const metrics = MOCK_DASHBOARD_METRICS;
  const orders = MOCK_ORDERS;
  const funnelData = getFunnelData(orders);

  // Recent orders (last 5)
  const recentOrders = [...orders]
    .sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
    .slice(0, 5);

  // Hot deadlines (within 7 days)
  const hotOrders = orders.filter(o => {
    if (!o.timeline.deadline || o.status === 'COMPLETED' || o.status === 'CANCELLED') return false;
    const deadline = new Date(o.timeline.deadline);
    const now = new Date();
    const daysLeft = Math.ceil((deadline.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
    return daysLeft <= 7 && daysLeft >= 0;
  });

  return (
    <div className="flex-1 overflow-y-auto crm-scroll p-6 space-y-6 bg-[#F5F6FA]">
      {/* Page title */}
      <div className="flex items-center justify-between">
        <div>
          <h2 className="text-xl font-bold text-gray-900">Общее</h2>
          <p className="text-sm text-gray-500 mt-0.5">Обзор ключевых показателей</p>
        </div>
        <div className="flex items-center gap-2">
          <select className="text-xs bg-white border border-[#E2E8F0] rounded-lg px-3 py-2 text-gray-600 outline-none focus:border-[#2A5CAA]/30">
            <option>Этот месяц</option>
            <option>Прошлый месяц</option>
            <option>Этот квартал</option>
            <option>Этот год</option>
          </select>
        </div>
      </div>

      {/* Metrics grid */}
      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 animate-fade-in">
        <MetricCard
          title="Количество заказов"
          value={metrics.totalOrders}
          change={metrics.totalOrdersChange}
          icon={<ShoppingCart size={18} />}
        />
        <MetricCard
          title="Средний чек"
          value={formatUAH(metrics.averageCheck)}
          change={metrics.averageCheckChange}
          icon={<DollarSign size={18} />}
        />
        <MetricCard
          title="Доход"
          value={formatUAH(metrics.revenue)}
          change={metrics.revenueChange}
          icon={<TrendingUp size={18} />}
        />
        <MetricCard
          title="Всего оплат"
          value={formatUAH(metrics.totalPayments)}
          change={metrics.totalPaymentsChange}
          icon={<CreditCard size={18} />}
        />
        <MetricCard
          title="Расходы (всего)"
          value={formatUAH(metrics.totalExpenses)}
          change={metrics.totalExpensesChange}
          icon={<Receipt size={18} />}
        />
        <MetricCard
          title="Отменённые заказы"
          value={metrics.canceledOrders}
          change={metrics.canceledOrdersChange}
          icon={<XCircle size={18} />}
        />
      </div>

      {/* Charts row */}
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-4">
        {/* Revenue trend */}
        <div className="lg:col-span-2 bg-white rounded-xl p-5 border border-[#E2E8F0]">
          <div className="flex items-center justify-between mb-4">
            <h3 className="text-sm font-semibold text-gray-900">Количество заказов по источникам</h3>
            <div className="flex items-center gap-2 text-xs">
              <label className="flex items-center gap-1.5 cursor-pointer">
                <input type="checkbox" defaultChecked className="rounded border-gray-300" />
                <span className="text-gray-500">Предыдущий период</span>
              </label>
            </div>
          </div>
          <div className="h-64">
            <ResponsiveContainer width="100%" height="100%">
              <AreaChart data={revenueChartData}>
                <defs>
                  <linearGradient id="colorOrders" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="5%" stopColor="#2A5CAA" stopOpacity={0.15} />
                    <stop offset="95%" stopColor="#2A5CAA" stopOpacity={0} />
                  </linearGradient>
                </defs>
                <CartesianGrid strokeDasharray="3 3" stroke="#F1F5F9" />
                <XAxis dataKey="month" tick={{ fontSize: 11, fill: '#94A3B8' }} axisLine={false} tickLine={false} />
