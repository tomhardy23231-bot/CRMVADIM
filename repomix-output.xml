<file path="src/components/crm/Finance.tsx">
'use client';

import React, { useState } from 'react';
import {
  DollarSign,
  TrendingUp,
  TrendingDown,
  ArrowUpRight,
  ArrowDownRight,
  Filter,
  Calendar,
} from 'lucide-react';
import { formatUAH, formatNumber } from '@/lib/crm-utils';
import { MOCK_ORDERS } from '@/lib/mock-data';
import {
  BarChart,
  Bar,
  XAxis,
  YAxis,
  CartesianGrid,
  Tooltip,
  ResponsiveContainer,
  LineChart,
  Line,
} from 'recharts';

// Mock revenue chart data
const monthlyData = [
  { month: 'Янв', income: 45000, expense: 28000 },
  { month: 'Фев', income: 62000, expense: 35000 },
  { month: 'Мар', income: 98000, expense: 52000 },
  { month: 'Апр', income: 23660, expense: 8500 },
  { month: 'Май', income: 0, expense: 0 },
  { month: 'Июн', income: 0, expense: 0 },
];

export default function Finance() {
  const totalIncome = monthlyData.reduce((s, d) => s + d.income, 0);
  const totalExpense = monthlyData.reduce((s, d) => s + d.expense, 0);
  const netProfit = totalIncome - totalExpense;

  // Top clients by amount
  const topClients = MOCK_ORDERS
    .filter(o => o.status !== 'CANCELLED')
    .sort((a, b) => b.amount - a.amount)
    .slice(0, 5);

  // Manager stats
  const managerStats = [
    { name: 'Валентина Полевая', orders: 4, amount: 273000, color: '#2A5CAA' },
    { name: 'Виктория Плетнева', orders: 2, amount: 137000, color: '#3B82F6' },
    { name: 'Сергей Коваленко', orders: 2, amount: 104000, color: '#60A5FA' },
  ];

  return (
    <div className="flex-1 overflow-y-auto crm-scroll p-6 space-y-6 bg-[#F5F6FA]">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div>
          <h2 className="text-xl font-bold text-gray-900">Финансы</h2>
          <p className="text-sm text-gray-500 mt-0.5">Финансовая аналитика и отчёты</p>
        </div>
        <div className="flex items-center gap-2">
          <input
            type="date"
            className="text-xs bg-white border border-[#E2E8F0] rounded-lg px-3 py-2 text-gray-600 outline-none"
          />
          <span className="text-gray-400 text-xs">—</span>
          <input
            type="date"
            className="text-xs bg-white border border-[#E2E8F0] rounded-lg px-3 py-2 text-gray-600 outline-none"
          />
        </div>
      </div>

      {/* Metrics */}
      <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div className="bg-white rounded-xl p-4 border border-[#E2E8F0]">
          <div className="flex items-center justify-between">
            <p className="text-xs font-medium text-[#64748B] uppercase tracking-wider">Общий доход</p>
            <div className="p-2 rounded-lg bg-emerald-50 text-emerald-500"><ArrowUpRight size={16} /></div>
          </div>
          <p className="text-xl font-bold text-gray-900 mt-2">{formatUAH(totalIncome)}</p>
        </div>
        <div className="bg-white rounded-xl p-4 border border-[#E2E8F0]">
          <div className="flex items-center justify-between">
            <p className="text-xs font-medium text-[#64748B] uppercase tracking-wider">Общие расходы</p>
            <div className="p-2 rounded-lg bg-red-50 text-red-500"><ArrowDownRight size={16} /></div>
          </div>
          <p className="text-xl font-bold text-gray-900 mt-2">{formatUAH(totalExpense)}</p>
        </div>
        <div className="bg-white rounded-xl p-4 border border-[#E2E8F0]">
          <div className="flex items-center justify-between">
            <p className="text-xs font-medium text-[#64748B] uppercase tracking-wider">Чистая прибыль</p>
            <div className={`p-2 rounded-lg ${netProfit >= 0 ? 'bg-emerald-50 text-emerald-500' : 'bg-red-50 text-red-500'}`}>
              {netProfit >= 0 ? <TrendingUp size={16} /> : <TrendingDown size={16} />}
            </div>
          </div>
          <p className={`text-xl font-bold mt-2 ${netProfit >= 0 ? 'text-emerald-600' : 'text-red-500'}`}>
            {formatUAH(netProfit)}
          </p>
        </div>
      </div>

      {/* Charts */}
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-4">
        {/* Revenue bar chart */}
        <div className="bg-white rounded-xl p-5 border border-[#E2E8F0]">
          <h3 className="text-sm font-semibold text-gray-900 mb-4">Доход vs Расходы</h3>
          <div className="h-64">
            <ResponsiveContainer width="100%" height="100%">
              <BarChart data={monthlyData}>
                <CartesianGrid strokeDasharray="3 3" stroke="#F1F5F9" />
                <XAxis dataKey="month" tick={{ fontSize: 11, fill: '#94A3B8' }} axisLine={false} tickLine={false} />
                <YAxis tick={{ fontSize: 11, fill: '#94A3B8' }} axisLine={false} tickLine={false} />
                <Tooltip
                  contentStyle={{
                    backgroundColor: '#fff',
                    border: '1px solid #E2E8F0',
                    borderRadius: '8px',
                    fontSize: '12px',
                  }}
                  formatter={(value: number, name: string) => [formatUAH(value), name === 'income' ? 'Доход' : 'Расходы']}
                />
                <Bar dataKey="income" fill="#2A5CAA" radius={[4, 4, 0, 0]} name="income" />
                <Bar dataKey="expense" fill="#F87171" radius={[4, 4, 0, 0]} name="expense" />
              </BarChart>
            </ResponsiveContainer>
          </div>
        </div>

        {/* Manager performance */}
        <div className="bg-white rounded-xl p-5 border border-[#E2E8F0]">
          <h3 className="text-sm font-semibold text-gray-900 mb-4">По менеджерам</h3>
          <div className="space-y-4">
            {managerStats.map(m => (
              <div key={m.name}>
                <div className="flex items-center justify-between mb-1.5">
                  <div className="flex items-center gap-2">
                    <div className="w-6 h-6 rounded-full text-white text-[10px] font-bold flex items-center justify-center" style={{ backgroundColor: m.color }}>
                      {m.name.split(' ').map(n => n[0]).join('')}
                    </div>
                    <span className="text-sm text-gray-700">{m.name}</span>
                  </div>
                  <div className="text-right">
                    <span className="text-sm font-semibold text-gray-900">{formatUAH(m.amount)}</span>
                    <span className="text-xs text-gray-400 ml-2">{m.orders} зак.</span>
                  </div>
                </div>
                <div className="w-full bg-[#F5F6FA] rounded-full h-2">
                  <div
                    className="h-2 rounded-full transition-all"
                    style={{
                      backgroundColor: m.color,
                      width: `${(m.amount / 273000) * 100}%`,
                    }}
                  />
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* Top orders table */}
      <div className="bg-white rounded-xl border border-[#E2E8F0]">
        <div className="flex items-center justify-between p-4 border-b border-[#F1F5F9]">
          <h3 className="text-sm font-semibold text-gray-900">Топ заказов по сумме</h3>
        </div>
        <table className="w-full crm-table">
          <thead>
            <tr>
              <th>Заказ</th>
              <th>Клиент</th>
              <th>Статус</th>
              <th>Сумма</th>
              <th>Прибыль</th>
            </tr>
          </thead>
          <tbody>
            {topClients.map(order => {
              const profit = order.amount - order.plannedCost;
              const margin = order.amount > 0 ? (profit / order.amount) * 100 : 0;
              return (
                <tr key={order.id}>
                  <td>
                    <span className="text-xs font-mono text-[#2A5CAA]">#{order.id}</span>
                    <span className="ml-2 text-sm font-medium">{order.title}</span>
                  </td>
                  <td className="text-sm text-gray-500">{order.clientName}</td>
                  <td>
                    <span className="status-badge bg-emerald-100 text-emerald-700">
                      {order.status === 'COMPLETED' ? 'Выполнен' : order.status === 'SHIPPED' ? 'Отгружен' : order.status === 'IN_PRODUCTION' ? 'В производстве' : order.status === 'ASSEMBLY' ? 'Сборка' : 'Новый'}
                    </span>
                  </td>
                  <td className="font-semibold text-sm">{formatUAH(order.amount)}</td>
                  <td>
                    <span className={`text-sm font-semibold ${margin > 20 ? 'text-emerald-600' : 'text-amber-600'}`}>
                      {formatUAH(profit)}
                    </span>
                    <span className="text-[10px] text-gray-400 ml-1">({margin.toFixed(0)}%)</span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  );
}
</file>

<file path="src/components/crm/Header.tsx">
'use client';

import React from 'react';
import {
  ArrowLeft,
  Search,
  Globe,
  RefreshCw,
  Plus,
  ChevronRight,
  Menu,
} from 'lucide-react';
import { PageId } from '@/lib/crm-types';

interface HeaderProps {
  currentPage: PageId;
  onNavigate: (page: PageId) => void;
  onToggleSidebar: () => void;
  pageTitle: string;
  breadcrumbs?: string[];
}

const PAGE_TITLES: Record<PageId, string> = {
  dashboard: 'Дашборд',
  orders: 'Продажи',
  'order-detail': 'Заказ',
  calendar: 'Платежный календарь',
  settings: 'Настройки',
  finance: 'Финансы',
};

export default function Header({
  currentPage,
  onNavigate,
  onToggleSidebar,
  pageTitle,
  breadcrumbs = [],
}: HeaderProps) {
  return (
    <header className="h-14 bg-white border-b border-[#E2E8F0] flex items-center px-4 gap-3 shrink-0">
      {/* Mobile menu button */}
      <button
        onClick={onToggleSidebar}
        className="lg:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors"
      >
        <Menu size={20} className="text-gray-500" />
      </button>

      {/* Breadcrumbs */}
      <div className="flex items-center gap-1 text-sm min-w-0">
        {breadcrumbs.length > 0 ? (
          <>
            {breadcrumbs.map((crumb, i) => (
              <React.Fragment key={i}>
                {i > 0 && (
                  <ChevronRight size={14} className="text-gray-300 shrink-0" />
                )}
                <button
                  onClick={() => {
                    if (i === 0) onNavigate('orders');
                  }}
                  className={`truncate hover:text-[#2A5CAA] transition-colors ${
                    i === breadcrumbs.length - 1
                      ? 'text-gray-900 font-medium'
                      : 'text-gray-500'
                  }`}
                >
                  {crumb}
                </button>
              </React.Fragment>
            ))}
          </>
        ) : (
          <h1 className="text-gray-900 font-semibold truncate">{pageTitle || PAGE_TITLES[currentPage]}</h1>
        )}
      </div>

      <div className="flex-1" />

      {/* Search bar */}
      <div className="hidden md:flex items-center bg-[#F5F6FA] rounded-lg px-3 py-2 w-64 border border-transparent focus-within:border-[#2A5CAA]/30 focus-within:bg-white transition-all">
        <Search size={16} className="text-gray-400 mr-2 shrink-0" />
        <input
          type="text"
          placeholder="Быстрый поиск..."
          className="bg-transparent text-sm outline-none w-full text-gray-700 placeholder-gray-400"
        />
      </div>

      {/* Actions */}
      <div className="flex items-center gap-2">
        {/* 1C Sync */}
        <button className="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-gray-600 hover:bg-gray-100 rounded-lg transition-colors">
          <RefreshCw size={14} />
          <span className="hidden sm:inline">Синхр. 1С</span>
        </button>

        {/* Add order button */}
        <button
          onClick={() => onNavigate('orders')}
          className="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-[#2A5CAA] text-white hover:bg-[#1E4380] rounded-lg transition-colors"
        >
          <Plus size={14} />
          <span className="hidden sm:inline">Добавить</span>
        </button>
      </div>
    </header>
  );
}
