                                </div>
                                <span className={cn('text-[9px] font-black', bal < 0 ? 'text-red-500' : 'text-emerald-600')}>
                                  {bal < 0 ? '−' : '+'}{formatUAH(Math.abs(bal)).replace('₴','').trim()}₴
                                </span>
                              </div>
                            </>
                          ) : (
                            <p className="text-[10px] text-gray-300 py-1">— нет данных</p>
                          )}
                        </div>
                      </div>
