// Status counts for filters
export function getStatusCounts(orders: Order[]): Record<string, number> {
  const counts: Record<string, number> = { ALL: orders.length };
  orders.forEach(o => {
    counts[o.status] = (counts[o.status] || 0) + 1;
  });
  return counts;
}
