<file path="src/components/crm/OrderDetail.tsx">
'use client';

import React, { useState } from 'react';
import {
  ArrowLeft,
  Phone,
  Mail,
  MessageSquare,
  Plus,
  Edit3,
  Trash2,
  ChevronDown,
  ChevronRight,
  Package,
  CreditCard,
  FileSpreadsheet,
  Calendar,
  Clock,
  CheckCircle2,
  AlertCircle,
  Copy,
  Download,
  FileText,
  Printer,
} from 'lucide-react';
import { MOCK_ORDERS, MOCK_MANAGERS } from '@/lib/mock-data';
import { Order, PageId, STATUS_LABELS, STATUS_COLORS, PAYMENT_STATUS_LABELS, PAYMENT_STATUS_COLORS, OrderStatus } from '@/lib/crm-types';
import { formatUAH, formatDate } from '@/lib/crm-utils';

interface OrderDetailProps {
  orderId: string;
  onNavigate: (page: PageId) => void;
  onBack: () => void;
}

type TabKey = 'info' | 'products' | 'payments' | 'budget' | 'timeline' | 'spec';

const TABS: { key: TabKey; label: string; icon: React.ReactNode }[] = [
  { key: 'info', label: 'Информация', icon: <FileText size={16} /> },
  { key: 'products', label: 'Товары', icon: <Package size={16} /> },
  { key: 'payments', label: 'Оплаты', icon: <CreditCard size={16} /> },
  { key: 'budget', label: 'Бюджет', icon: <FileSpreadsheet size={16} /> },
  { key: 'timeline', label: 'Таймлайн', icon: <Calendar size={16} /> },
];

// Status stepper
const STATUS_STEPS: OrderStatus[] = ['NEW', 'IN_PRODUCTION', 'ASSEMBLY', 'SHIPPED', 'COMPLETED'];

export default function OrderDetail({ orderId, onNavigate, onBack }: OrderDetailProps) {
  const [activeTab, setActiveTab] = useState<TabKey>('info');
  const [expandedSections, setExpandedSections] = useState<Record<string, boolean>>({
    info: true,
    contact: true,
  });

  const order = MOCK_ORDERS.find(o => o.id === orderId);

  if (!order) {
    return (
      <div className="flex-1 flex items-center justify-center bg-[#F5F6FA]">
        <div className="text-center">
          <AlertCircle size={48} className="mx-auto text-gray-300 mb-3" />
          <p className="text-gray-500">Заказ не найден</p>
          <button onClick={onBack} className="mt-3 text-sm text-[#2A5CAA] hover:underline">
            Вернуться к списку
          </button>
        </div>
      </div>
    );
  }

  const manager = MOCK_MANAGERS.find(m => m.id === order.managerId);
  const profit = order.amount - order.plannedCost;
  const margin = order.amount > 0 ? (profit / order.amount) * 100 : 0;
  const currentStepIdx = STATUS_STEPS.indexOf(order.status);
  const totalPayments = order.payments.reduce((s, p) => s + p.income, 0);
  const totalExpenses = order.payments.reduce((s, p) => s + p.expense, 0);

  const toggleSection = (key: string) => {
    setExpandedSections(prev => ({ ...prev, [key]: !prev[key] }));
  };

  return (
    <div className="flex-1 flex flex-col overflow-hidden bg-[#F5F6FA]">
      {/* Order header bar (keyCRM style) */}
      <div className="bg-white border-b border-[#E2E8F0] px-4 py-3 shrink-0">
        <div className="flex items-center gap-3">
          <button onClick={onBack} className="p-1.5 rounded-lg hover:bg-gray-100 transition-colors">
            <ArrowLeft size={18} className="text-gray-500" />
          </button>

          <div className="flex items-center gap-2">
            <span className="text-xs font-mono text-[#2A5CAA] font-semibold">#{order.id}</span>
            <span className="text-sm font-medium text-gray-900">{order.title}</span>
            <span className={`status-badge ${STATUS_COLORS[order.status]}`}>
              {STATUS_LABELS[order.status]}
            </span>
            <span className={`status-badge ${PAYMENT_STATUS_COLORS[order.paymentStatus]}`}>
              {PAYMENT_STATUS_LABELS[order.paymentStatus]}
            </span>
          </div>

          <div className="flex-1" />

          {/* Actions */}
          <div className="flex items-center gap-1.5">
            <button className="p-2 rounded-lg hover:bg-gray-100 text-gray-400 transition-colors" title="Копировать">
              <Copy size={16} />
            </button>
            <button className="p-2 rounded-lg hover:bg-gray-100 text-gray-400 transition-colors" title="Печать">
              <Printer size={16} />
            </button>
            <button className="p-2 rounded-lg hover:bg-gray-100 text-gray-400 transition-colors" title="Скачать">
              <Download size={16} />
            </button>
            <button className="flex items-center gap-1 px-3 py-1.5 text-xs font-medium bg-[#2A5CAA] text-white hover:bg-[#1E4380] rounded-lg transition-colors">
              <Edit3 size={14} />
              Редактировать
            </button>
          </div>
        </div>

        {/* Status stepper */}
        <div className="flex items-center gap-0 mt-3 ml-9">
          {STATUS_STEPS.map((step, i) => {
            const isCompleted = i <= currentStepIdx && order.status !== 'CANCELLED';
            const isCurrent = i === currentStepIdx;
            const isCancelled = order.status === 'CANCELLED';
            return (
              <React.Fragment key={step}>
                <div className="flex items-center gap-2">
                  <div
                    className={`w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold transition-all ${
                      isCancelled
                        ? 'bg-red-100 text-red-500'
                        : isCompleted
                        ? 'bg-[#2A5CAA] text-white'
                        : 'bg-gray-100 text-gray-400'
                    }`}
                  >
                    {isCompleted && !isCancelled ? <CheckCircle2 size={14} /> : i + 1}
                  </div>
                  <span className={`text-xs font-medium whitespace-nowrap ${
                    isCancelled
                      ? 'text-red-500 line-through'
                      : isCompleted
                      ? 'text-[#2A5CAA]'
                      : 'text-gray-400'
                  }`}>
                    {STATUS_LABELS[step]}
                  </span>
                </div>
                {i < STATUS_STEPS.length - 1 && (
                  <div className={`flex-1 h-0.5 mx-2 min-w-[20px] ${
                    i < currentStepIdx && !isCancelled ? 'bg-[#2A5CAA]' : 'bg-gray-200'
                  }`} />
                )}
              </React.Fragment>
            );
          })}
        </div>
      </div>

      {/* Tabs */}
      <div className="bg-white border-b border-[#E2E8F0] px-4 shrink-0">
        <div className="flex items-center gap-0">
          {TABS.map(tab => (
            <button
              key={tab.key}
              onClick={() => setActiveTab(tab.key)}
              className={`flex items-center gap-1.5 px-4 py-3 text-xs font-medium border-b-2 transition-colors whitespace-nowrap ${
                activeTab === tab.key
                  ? 'border-[#2A5CAA] text-[#2A5CAA]'
                  : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'
              }`}
            >
              {tab.icon}
              {tab.label}
              {tab.key === 'products' && order.specItems.length > 0 && (
                <span className="bg-[#F5F6FA] text-gray-500 text-[10px] px-1.5 py-0.5 rounded-full">
                  {order.specItems.length}
                </span>
              )}
            </button>
          ))}
        </div>
      </div>

      {/* Content */}
      <div className="flex-1 overflow-y-auto crm-scroll p-4">
        {/* Info tab */}
        {activeTab === 'info' && (
          <div className="space-y-4 animate-fade-in max-w-4xl">
            {/* Financial summary */}
            <div className="grid grid-cols-2 sm:grid-cols-4 gap-3">
              <div className="bg-white rounded-xl p-4 border border-[#E2E8F0]">
                <p className="text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Сумма заказа</p>
                <p className="text-lg font-bold text-gray-900 mt-1">{formatUAH(order.amount)}</p>
                {order.isAmountManual && (
                  <span className="text-[10px] text-blue-500 font-medium">Вручную</span>
                )}
              </div>
              <div className="bg-white rounded-xl p-4 border border-[#E2E8F0]">
                <p className="text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Себестоимость</p>
                <p className="text-lg font-bold text-gray-500 mt-1">{formatUAH(order.plannedCost)}</p>
              </div>
              <div className="bg-white rounded-xl p-4 border border-[#E2E8F0]">
                <p className="text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Прибыль</p>
                <p className={`text-lg font-bold mt-1 ${margin > 20 ? 'text-emerald-600' : margin > 10 ? 'text-amber-600' : 'text-red-500'}`}>
                  {formatUAH(profit)}
                </p>
                <span className={`text-[10px] font-medium ${margin > 20 ? 'text-emerald-500' : margin > 10 ? 'text-amber-500' : 'text-red-400'}`}>
                  Маржа: {margin.toFixed(1)}%
                </span>
              </div>
              <div className="bg-white rounded-xl p-4 border border-[#E2E8F0]">
                <p className="text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Оплата</p>
                <p className="text-lg font-bold text-[#2A5CAA] mt-1">{formatUAH(totalPayments)}</p>
                <span className={`text-[10px] font-medium ${
                  totalPayments >= order.amount ? 'text-emerald-500' : 'text-amber-500'
                }`}>
                  {order.amount > 0 ? ((totalPayments / order.amount) * 100).toFixed(0) : 0}% оплачено
                </span>
              </div>
            </div>

            {/* Client info section */}
            <div className="bg-white rounded-xl border border-[#E2E8F0] overflow-hidden">
              <button
                onClick={() => toggleSection('contact')}
                className="w-full flex items-center justify-between p-4 hover:bg-gray-50 transition-colors"
              >
                <h3 className="text-sm font-semibold text-gray-900">Информация о клиенте</h3>
                {expandedSections.contact ? <ChevronDown size={16} className="text-gray-400" /> : <ChevronRight size={16} className="text-gray-400" />}
              </button>
              {expandedSections.contact && (
                <div className="px-4 pb-4 border-t border-[#F1F5F9] pt-3 space-y-3 animate-fade-in">
                  <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <div>
                      <label className="text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Клиент</label>
                      <p className="text-sm font-medium text-gray-900 mt-1">{order.clientName}</p>
                    </div>
                    <div>
                      <label className="text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Менеджер</label>
                      <div className="flex items-center gap-2 mt-1">
                        <div className="w-6 h-6 rounded-full bg-[#2A5CAA]/10 text-[#2A5CAA] flex items-center justify-center text-[10px] font-bold">
                          {manager?.name.split(' ').map(n => n[0]).join('')}
                        </div>
                        <span className="text-sm text-gray-700">{manager?.name}</span>
                        <span className="text-[10px] text-gray-400">{manager?.role}</span>
                      </div>
                    </div>
                  </div>
                  <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <div>
                      <label className="text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Телефон покупателя</label>
                      <div className="flex items-center gap-2 mt-1">
                        <Phone size={14} className="text-[#2A5CAA]" />
                        <span className="text-sm text-gray-900">{order.clientPhone}</span>
                        <button className="text-xs text-[#2A5CAA] hover:text-[#1E4380] font-medium">Позвонить</button>
                      </div>
                    </div>
                    <div>
                      <label className="text-[10px] font-semibold text-gray-400 uppercase tracking-wider">E-mail покупателя</label>
                      <div className="flex items-center gap-2 mt-1">
                        <Mail size={14} className="text-[#2A5CAA]" />
                        {order.clientEmail ? (
                          <span className="text-sm text-gray-900">{order.clientEmail}</span>
                        ) : (
                          <span className="text-sm text-gray-400">(пусто)</span>
                        )}
                        <button className="text-xs text-[#2A5CAA] hover:text-[#1E4380] font-medium">Написать</button>
                      </div>
                    </div>
                  </div>
                </div>
              )}
            </div>

            {/* Notes */}
            <div className="bg-white rounded-xl border border-[#E2E8F0] p-4">
              <h3 className="text-sm font-semibold text-gray-900 mb-2">Заметки</h3>
              <textarea
                className="w-full text-sm text-gray-700 bg-[#F5F6FA] border border-[#E2E8F0] rounded-lg p-3 outline-none focus:border-[#2A5CAA]/30 resize-none h-20"
                placeholder="Добавить заметку..."
                defaultValue={order.notes}
              />
            </div>
          </div>
        )}

        {/* Products tab */}
        {activeTab === 'products' && (
          <div className="animate-fade-in max-w-5xl">
            <div className="flex items-center justify-between mb-3">
              <h3 className="text-sm font-semibold text-gray-900">Товары ({order.specItems.length})</h3>
              <button className="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-[#2A5CAA] text-white hover:bg-[#1E4380] rounded-lg transition-colors">
                <Plus size={14} />
                Добавить товар
              </button>
            </div>
            <div className="bg-white rounded-xl border border-[#E2E8F0] overflow-hidden">
              <table className="w-full crm-table">
                <thead>
                  <tr>
                    <th>Изображение</th>
                    <th>Название</th>
                    <th>Ед. изм.</th>
                    <th>Кол-во</th>
                    <th>Цена закупки</th>
                    <th>Цена продажи</th>
                    <th>Сумма</th>
                    <th>Себестоимость</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  {order.specItems.length === 0 ? (
                    <tr>
                      <td colSpan={9} className="text-center py-8 text-gray-400 text-sm">
                        Нет товаров. Нажмите "Добавить товар"
                      </td>
                    </tr>
                  ) : (
                    order.specItems.map(item => (
                      <tr key={item.id}>
                        <td>
                          <div className="w-10 h-10 rounded-lg bg-[#F5F6FA] flex items-center justify-center">
                            <Package size={16} className="text-gray-400" />
                          </div>
                        </td>
                        <td className="font-medium text-sm text-gray-900">{item.material}</td>
                        <td className="text-xs text-gray-500">{item.unit}</td>
                        <td className="text-sm font-medium">{item.quantity}</td>
                        <td className="text-sm text-gray-500">{formatUAH(item.cost / item.quantity)}</td>
                        <td className="text-sm font-semibold">{formatUAH(item.price)}</td>
                        <td className="text-sm font-semibold">{formatUAH(item.total)}</td>
                        <td className="text-sm text-gray-500">{formatUAH(item.cost)}</td>
                        <td>
                          <button className="p-1 rounded hover:bg-gray-100">
                            <MoreVIcon />
                          </button>
                        </td>
                      </tr>
                    ))
                  )}
                </tbody>
              </table>

              {/* Summary */}
              {order.specItems.length > 0 && (
                <div className="bg-[#F8F9FB] px-4 py-3 flex items-center justify-between text-sm border-t border-[#E2E8F0]">
                  <div className="space-x-6">
                    <span className="text-gray-500">
                      Сумма за товары: <strong className="text-gray-900">{formatUAH(order.specItems.reduce((s, i) => s + i.total, 0))}</strong>
                    </span>
                    <span className="text-gray-500">
                      Скидка к заказу: <strong className="text-gray-900">{formatUAH(0)}</strong>
                    </span>
                  </div>
                  <div className="font-bold text-gray-900">
                    Сумма к оплате: {formatUAH(order.amount)}
                  </div>
                </div>
              )}
            </div>
          </div>
        )}

        {/* Payments tab */}
        {activeTab === 'payments' && (
          <div className="animate-fade-in max-w-5xl">
            <div className="flex items-center justify-between mb-3">
              <h3 className="text-sm font-semibold text-gray-900">Оплаты ({order.payments.length})</h3>
              <button className="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-[#2A5CAA] text-white hover:bg-[#1E4380] rounded-lg transition-colors">
                <Plus size={14} />
                Добавить оплату
              </button>
            </div>
            <div className="bg-white rounded-xl border border-[#E2E8F0] overflow-hidden">
              <table className="w-full crm-table">
                <thead>
                  <tr>
                    <th>Дата и время</th>
                    <th>Документ</th>
                    <th>Приход</th>
                    <th>Расход</th>
                    <th>Статья</th>
                    <th>Статус</th>
                  </tr>
                </thead>
                <tbody>
                  {order.payments.length === 0 ? (
                    <tr>
                      <td colSpan={6} className="text-center py-8 text-gray-400 text-sm">
                        Нет оплат
                      </td>
                    </tr>
                  ) : (
                    order.payments.map(p => (
                      <tr key={p.id}>
                        <td className="text-xs text-gray-500 whitespace-nowrap">{p.date}</td>
                        <td className="text-sm text-gray-900 max-w-[200px] truncate">{p.document}</td>
                        <td className={p.income > 0 ? 'text-sm font-semibold text-emerald-600' : 'text-sm text-gray-400'}>
                          {p.income > 0 ? formatUAH(p.income) : '—'}
                        </td>
                        <td className={p.expense > 0 ? 'text-sm font-semibold text-red-500' : 'text-sm text-gray-400'}>
                          {p.expense > 0 ? formatUAH(p.expense) : '—'}
                        </td>
                        <td className="text-xs text-gray-500">{p.article || '—'}</td>
                        <td>
                          <span className="status-badge bg-emerald-100 text-emerald-700">Проведен</span>
                        </td>
                      </tr>
                    ))
                  )}
                </tbody>
              </table>

              {/* Summary */}
              <div className="bg-[#F8F9FB] px-4 py-3 flex items-center gap-6 text-sm border-t border-[#E2E8F0]">
                <span className="text-gray-500">
                  Всего приход: <strong className="text-emerald-600">{formatUAH(totalPayments)}</strong>
                </span>
                <span className="text-gray-500">
                  Всего расход: <strong className="text-red-500">{formatUAH(totalExpenses)}</strong>
                </span>
                <span className="text-gray-500">
                  Остаток: <strong className="text-gray-900">{formatUAH(totalPayments - totalExpenses)}</strong>
                </span>
              </div>
            </div>
          </div>
        )}

        {/* Budget tab */}
        {activeTab === 'budget' && (
          <div className="animate-fade-in max-w-5xl">
            <div className="flex items-center justify-between mb-3">
              <h3 className="text-sm font-semibold text-gray-900">Бюджет ({order.budgetItems.length})</h3>
              <div className="flex items-center gap-2">
                <button className="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium border border-[#E2E8F0] text-gray-600 hover:bg-gray-50 rounded-lg transition-colors">
                  <Download size={14} />
                  Выгрузить Excel
                </button>
                <button className="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-[#2A5CAA] text-white hover:bg-[#1E4380] rounded-lg transition-colors">
                  <Plus size={14} />
                  Добавить статью
                </button>
              </div>
            </div>
            <div className="bg-white rounded-xl border border-[#E2E8F0] overflow-hidden">
              <table className="w-full crm-table">
                <thead>
                  <tr>
                    <th>Статья</th>
                    <th>Тип</th>
                    <th>План</th>
                    <th>Факт</th>
                    <th>Отклонение</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  {order.budgetItems.map(item => {
                    const dev = item.plan > 0 ? ((item.fact - item.plan) / item.plan) * 100 : 0;
                    return (
                      <tr key={item.id}>
                        <td className="font-medium text-sm text-gray-900">
                          {item.name}
                          {item.locked && (
                            <span className="ml-2 text-[10px] bg-gray-100 text-gray-400 px-1.5 py-0.5 rounded">
                              <Lock size={10} className="inline" />
                            </span>
                          )}
                        </td>
                        <td>
                          <span className={`status-badge ${item.type === 'INCOME' ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-600'}`}>
                            {item.type === 'INCOME' ? 'Доход' : 'Расход'}
                          </span>
                        </td>
                        <td className="text-sm font-medium">{formatUAH(item.plan)}</td>
                        <td className={`text-sm font-semibold ${item.type === 'INCOME' ? 'text-emerald-600' : 'text-red-500'}`}>
                          {formatUAH(item.fact)}
                        </td>
                        <td>
                          <span className={`text-sm font-medium ${Math.abs(dev) < 5 ? 'text-gray-500' : dev > 0 ? 'text-amber-600' : 'text-red-500'}`}>
                            {dev.toFixed(1)}%
                          </span>
                        </td>
                        <td>
                          {!item.locked && (
                            <button className="p-1 rounded hover:bg-gray-100">
                              <Edit3 size={14} className="text-gray-400" />
                            </button>
                          )}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>

              {/* Total */}
              <div className="bg-[#F8F9FB] px-4 py-3 flex items-center gap-6 text-sm border-t border-[#E2E8F0]">
                <span className="text-gray-500">
                  Расходы (план): <strong className="text-gray-900">{formatUAH(order.budgetItems.filter(b => b.type === 'EXPENSE').reduce((s, b) => s + b.plan, 0))}</strong>
                </span>
                <span className="text-gray-500">
                  Доходы (факт): <strong className="text-emerald-600">{formatUAH(order.budgetItems.filter(b => b.type === 'INCOME').reduce((s, b) => s + b.fact, 0))}</strong>
                </span>
              </div>
            </div>
          </div>
        )}

        {/* Timeline tab */}
        {activeTab === 'timeline' && (
          <div className="animate-fade-in max-w-2xl">
            <div className="bg-white rounded-xl border border-[#E2E8F0] p-5">
              <h3 className="text-sm font-semibold text-gray-900 mb-4">Даты и этапы</h3>
              <div className="space-y-4">
                {[
                  { label: 'Начало производства', date: order.timeline.productionStart, icon: <Factory size={16} /> },
                  { label: 'Начало сборки', date: order.timeline.assemblyStart, icon: <Package size={16} /> },
                  { label: 'Дата отгрузки', date: order.timeline.shippingDate, icon: <Truck size={16} /> },
                  { label: 'Дедлайн', date: order.timeline.deadline, icon: <Clock size={16} /> },
                ].map((item, i) => (
                  <div key={i} className="flex items-center gap-3">
                    <div className={`p-2 rounded-lg ${item.date ? 'bg-[#2A5CAA]/10 text-[#2A5CAA]' : 'bg-gray-100 text-gray-400'}`}>
                      {item.icon}
                    </div>
                    <div className="flex-1">
                      <p className="text-sm font-medium text-gray-900">{item.label}</p>
                    </div>
                    <div className="bg-[#F5F6FA] border border-[#E2E8F0] rounded-lg px-3 py-1.5 text-sm text-gray-700 min-w-[140px] text-center">
                      {item.date ? formatDate(item.date) : 'Не задано'}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

// Helper icons used in table
function MoreVIcon() {
