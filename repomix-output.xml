                                  <span className="text-[11px] font-black text-emerald-600">{formatUAH(inc)}</span>
                                </div>
                              )}
                              {exp > 0 && (
                                <div className="flex items-center justify-between">
                                  <span className="text-[9px] font-bold text-red-400/70 uppercase">Расход</span>
