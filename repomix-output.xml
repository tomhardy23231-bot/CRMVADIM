# Инструкция по настройке интеграции 1С:Предприятие и CRM

Данное руководство предназначено для настройки обмена данными между рабочей (боевой) базой 1С:Предприятие (УТ, УПП, ERP) и веб-CRM системой. Обмен осуществляется через HTTP-сервис на стороне 1С.

---

## 1. Подготовка конфигурации 1С

### 1.1 Создание HTTP-сервиса
1. Откройте **Конфигуратор** рабочей базы 1С.
2. В дереве метаданных найдите ветку **Общие -> HTTP-сервисы**.
3. Добавьте новый HTTP-сервис. Назовите его `CrmApi`.
4. В поле **Корневой URL** укажите: `crm`.
5. В поле **Повторное использование сеансов** выберите: `Автоматически`.

### 1.2 Настройка шаблонов URL
Внутри созданного HTTP-сервиса `CrmApi` создайте 4 шаблона URL:

1. **Ping**
   * Шаблон: `/ping`
   * Добавьте метод `GET`. 
   * В поле "Обработчик" укажите функцию `PingGet`.

2. **Orders**
   * Шаблон: `/orders`
   * Добавьте метод `GET`. 
   * В поле "Обработчик" укажите функцию `OrdersGet`.

3. **ContractorInfo**
   * Шаблон: `/contractor`
   * Добавьте метод `GET`.
   * В поле "Обработчик" укажите функцию `ContractorGet`.

4. **ContractorsList**
   * Шаблон: `/contractors`
   * Добавьте метод `GET`.
   * В поле "Обработчик" укажите функцию `ContractorsListGet`.

---

## 2. Создание Общего Модуля

1. В ветке **Общие -> Общие модули** создайте новый модуль. Назовите его `CrmApi` (чтобы совпадало с обработчиками).
2. В свойствах модуля установите галочки:
   * Сервер
   * Вызов сервера
   * Привилегированный (обязательно, чтобы обойти ограничения RLS при чтении).
3. Откройте модуль и вставьте в него **полный код, приведенный ниже**.

> **Важно:** В этом коде реализована защита паролем `x-api-key: MySecretKey123`. Вы можете изменить пароль в строке `АпиКлюч <> "MySecretKey123"`, но тогда обязательно обновите его и в CRM (файл `src/app/api/1c/contractor/search/route.ts`).

### Умный алгоритм платежей (Взаиморасчеты)
Код написан так, чтобы быть устойчивым (fault-tolerant) к специфике вашей конфигурации. Он автоматически извлекает статью ДДС (или НазначениеПлатежа / Комментарий) и оборачивает всё в `Попытка-Исключение`, чтобы в случае отсутствия какого-либо поля в документе, 1С не прерывала отдачу массива платежей.

### Полный код модуля CrmApi:

```bsl
Функция ContractorGet(Запрос)
	
	АпиКлюч = Запрос.Заголовки.Получить("x-api-key");
	Если АпиКлюч <> "MySecretKey123" Тогда Возврат Новый HTTPСервисОтвет(401); КонецЕсли;

	ИмяИлиУНН = Запрос.ПараметрыЗапроса.Получить("name");
	Если ИмяИлиУНН = Неопределено Тогда Возврат Новый HTTPСервисОтвет(400); КонецЕсли;

	СпрКонтрагенты = Справочники.Контрагенты;
	Контрагент = СпрКонтрагенты.НайтиПоНаименованию(ИмяИлиУНН, Истина);
	Если Контрагент.Пустая() Тогда Контрагент = СпрКонтрагенты.НайтиПоНаименованию(ИмяИлиУНН, Ложь); КонецЕсли;
    
	Если Контрагент.Пустая() Тогда
		Ответ = Новый HTTPСервисОтвет(404);
		Ответ.УстановитьТелоИзСтроки("Контрагент не найден");
		Возврат Ответ;
	КонецЕсли;
	
	РезультатJSON = Новый Структура;
	СтруктураКонтрагента = Новый Структура;
	СтруктураКонтрагента.Вставить("id", Строка(Контрагент.УникальныйИдентификатор()));
	СтруктураКонтрагента.Вставить("name", Контрагент.Наименование);
	РезультатJSON.Вставить("contractor", СтруктураКонтрагента);
	
	// 1. ВЗАИМОРАСЧЕТЫ (Платежи) - ОСТАВЛЯЕМ ТОЛЬКО ДЕНЬГИ
	ТекстВзаиморасчеты = "ВЫБРАТЬ
		|	Взаиморасчеты.Период КАК Период,
		|	Взаиморасчеты.Регистратор КАК Регистратор,
		|	Взаиморасчеты.Регистратор.Представление КАК Документ,
		|	Взаиморасчеты.СуммаВзаиморасчетов КАК Сумма
		|ИЗ
		|	РегистрНакопления.ВзаиморасчетыСКонтрагентами КАК Взаиморасчеты
		|ГДЕ
		|	Взаиморасчеты.Контрагент = &Контрагент
		|УПОРЯДОЧИТЬ ПО Период УБЫВ";
	
	ЗапросВзаиморасчеты = Новый Запрос(ТекстВзаиморасчеты);
	ЗапросВзаиморасчеты.УстановитьПараметр("Контрагент", Контрагент);
	
	ВзаиморасчетыМассив = Новый Массив;
	Попытка
		ВыборкаВР = ЗапросВзаиморасчеты.Выполнить().Выбрать();
		Пока ВыборкаВР.Следующий() Цикл
			
			ДокИмяДлинное = НРег(ВыборкаВР.Документ);
			Выручка = 0; Оплата = 0;
			
			// === ОПРЕДЕЛЯЕМ ДОХОД/РАСХОД (ЗАЩИТА ОТ ОШИБОК КОНФИГУРАЦИИ) ===
			Если Найти(ДокИмяДлинное, "платежное поручение входящее") > 0 
			 Или Найти(ДокИмяДлинное, "приходный кассовый ордер") > 0
			 Или Найти(ДокИмяДлинное, "поступление безналичных") > 0
			 Или Найти(ДокИмяДлинное, "поступление на расчетный") > 0 Тогда
				Выручка = Макс(ВыборкаВР.Сумма, -ВыборкаВР.Сумма); // Входящие деньги
			ИначеЕсли Найти(ДокИмяДлинное, "платежное поручение исходящее") > 0
			 Или Найти(ДокИмяДлинное, "расходный кассовый ордер") > 0
			 Или Найти(ДокИмяДлинное, "списание безналичных") > 0
			 Или Найти(ДокИмяДлинное, "списание с расчетного") > 0 Тогда
				Оплата = Макс(ВыборкаВР.Сумма, -ВыборкаВР.Сумма); // Исходящие деньги
			Иначе
				// Пропускаем (это производство, возврат или реализация)
				Продолжить; 
			КонецЕсли;

			Стр = Новый Структура;
			Стр.Вставить("date", Формат(ВыборкаВР.Период, "ДФ=yyyy-MM-ddTHH:mm:ss"));
			Стр.Вставить("document", ВыборкаВР.Документ);
			Стр.Вставить("income", Выручка);
			Стр.Вставить("expense", Оплата);
			
			// === БЕЗОПАСНАЯ СТАТЬЯ ДДС ===
			СтатьяТекст = "";
			Попытка
				ДокОбъект = ВыборкаВР.Регистратор.ПолучитьОбъект();
				Если ДокОбъект <> Неопределено Тогда
					Попытка Если ЗначениеЗаполнено(ДокОбъект.СтатьяДДС) Тогда СтатьяТекст = Строка(ДокОбъект.СтатьяДДС); КонецЕсли; Исключение КонецПопытки;
					Если СтатьяТекст = "" Тогда Попытка Если ЗначениеЗаполнено(ДокОбъект.СтатьяДвиженияДенежныхСредств) Тогда СтатьяТекст = Строка(ДокОбъект.СтатьяДвиженияДенежныхСредств); КонецЕсли; Исключение КонецПопытки; КонецЕсли;
					Если СтатьяТекст = "" Тогда Попытка Если ЗначениеЗаполнено(ДокОбъект.НазначениеПлатежа) Тогда СтатьяТекст = Строка(ДокОбъект.НазначениеПлатежа); КонецЕсли; Исключение КонецПопытки; КонецЕсли;
					Если СтатьяТекст = "" Тогда Попытка Если ЗначениеЗаполнено(ДокОбъект.Комментарий) Тогда СтатьяТекст = Строка(ДокОбъект.Комментарий); КонецЕсли; Исключение КонецПопытки; КонецЕсли;
				КонецЕсли;
			Исключение
			КонецПопытки;
			// ===================================
			
			Стр.Вставить("article", СокрЛП(СтатьяТекст));
			ВзаиморасчетыМассив.Добавить(Стр);
		КонецЦикла;
	Исключение
		Сообщить("CRM API: ошибка взаиморасчетов: " + ОписаниеОшибки());
	КонецПопытки;
	РезультатJSON.Вставить("settlements", ВзаиморасчетыМассив);

	// 2. ПРОДАЖИ И СЕБЕСТОИМОСТЬ
	ТекстПродажи = "ВЫБРАТЬ
		|	Продажи.Период КАК Период,
		|	Продажи.Регистратор.Представление КАК Документ,
		|	Продажи.Номенклатура.Наименование КАК Товар,
		|	Продажи.Количество КАК Количество,
		|	Продажи.Стоимость КАК СуммаПродажи,
		|	ЕСТЬNULL(Себестоимость.Стоимость, 0) КАК Себестоимость
		|ИЗ
		|	РегистрНакопления.Продажи КАК Продажи
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ПродажиСебестоимость КАК Себестоимость
		|		ПО Продажи.Регистратор = Себестоимость.Регистратор
		|			И Продажи.Номенклатура = Себестоимость.Номенклатура
		|ГДЕ
		|	Продажи.Контрагент = &Контрагент
		|УПОРЯДОЧИТЬ ПО Период УБЫВ";
	
	ЗапросПродажи = Новый Запрос(ТекстПродажи);
	ЗапросПродажи.УстановитьПараметр("Контрагент", Контрагент);
	
	ПродажиМассив = Новый Массив;
	Попытка
		ВыборкаПр = ЗапросПродажи.Выполнить().Выбрать();
		Пока ВыборкаПр.Следующий() Цикл
			Стр = Новый Структура;
			Стр.Вставить("date", Формат(ВыборкаПр.Период, "ДФ=yyyy-MM-ddTHH:mm:ss"));
			Стр.Вставить("document", ВыборкаПр.Документ);
			Стр.Вставить("item", ВыборкаПр.Товар);
			Стр.Вставить("quantity", ВыборкаПр.Количество);
			Стр.Вставить("amount", ВыборкаПр.СуммаПродажи);
			Стр.Вставить("cost", ВыборкаПр.Себестоимость);
			ПродажиМассив.Добавить(Стр);
		КонецЦикла;
	Исключение
	КонецПопытки;
	РезультатJSON.Вставить("sales", ПродажиМассив);

	// 3. ЗАКАЗЫ
	ТекстЗаказы = "ВЫБРАТЬ
		|	Заказы.Период КАК Период,
		|	Заказы.Регистратор.Представление КАК Документ,
		|	Заказы.СуммаВзаиморасчетов КАК Сумма
		|ИЗ
		|	РегистрНакопления.ЗаказыПокупателей КАК Заказы
		|ГДЕ
		|	Заказы.Контрагент = &Контрагент
		|	И Заказы.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|УПОРЯДОЧИТЬ ПО Период УБЫВ";
	
	ЗапросЗаказы = Новый Запрос(ТекстЗаказы);
	ЗапросЗаказы.УстановитьПараметр("Контрагент", Контрагент);
	
	ЗаказыМассив = Новый Массив;
	Попытка
	    ВыборкаЗак = ЗапросЗаказы.Выполнить().Выбрать();
	    Пока ВыборкаЗак.Следующий() Цикл
		    Стр = Новый Структура;
		    Стр.Вставить("date", Формат(ВыборкаЗак.Период, "ДФ=yyyy-MM-ddTHH:mm:ss"));
		    Стр.Вставить("document", ВыборкаЗак.Документ);
		    Стр.Вставить("total", ВыборкаЗак.Сумма);
		    ЗаказыМассив.Добавить(Стр);
	    КонецЦикла;
	Исключение
	КонецПопытки;
	РезультатJSON.Вставить("orders", ЗаказыМассив);
	
	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку();
	ЗаписатьJSON(Запись, РезультатJSON);
	
	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(Запись.Закрыть(), КодировкаТекста.UTF8);
	Возврат Ответ;
	
КонецФункции

Функция ContractorsListGet(Запрос)
	НазваниеПапки = Запрос.ПараметрыЗапроса.Получить("folder");
	МассивКонтрагентов = Новый Массив;
	
