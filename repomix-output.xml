                  +{formatUAH(totalIncome)}
                </div>
              )}
              {totalExpense > 0 && (
                <div className="flex items-center gap-1 bg-red-50 text-red-700 text-xs font-semibold px-2.5 py-1.5 rounded-lg border border-red-200">
