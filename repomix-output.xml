<file path="src/components/crm/OrdersList.tsx">
'use client';

import React, { useState, useMemo } from 'react';
import {
  Search,
  Plus,
  Filter,
  ChevronDown,
  MoreVertical,
  Download,
  Trash2,
  Edit3,
  Eye,
  ArrowUpDown,
  Calendar,
  X,
} from 'lucide-react';
import { MOCK_ORDERS, getStatusCounts } from '@/lib/mock-data';
import { formatUAH, formatDateTime } from '@/lib/crm-utils';
import { Order, OrderStatus, STATUS_LABELS, STATUS_COLORS, PAYMENT_STATUS_LABELS, PAYMENT_STATUS_COLORS, PageId } from '@/lib/crm-types';

interface OrdersListProps {
  onNavigate: (page: PageId) => void;
  onSelectOrder: (orderId: string) => void;
}

type SortField = 'id' | 'title' | 'amount' | 'createdAt' | 'status';
type SortDir = 'asc' | 'desc';

export default function OrdersList({ onNavigate, onSelectOrder }: OrdersListProps) {
  const [searchQuery, setSearchQuery] = useState('');
  const [activeFilter, setActiveFilter] = useState<string>('ALL');
  const [sortField, setSortField] = useState<SortField>('createdAt');
  const [sortDir, setSortDir] = useState<SortDir>('desc');
  const [showFilters, setShowFilters] = useState(false);

  const orders = MOCK_ORDERS;
  const statusCounts = getStatusCounts(orders);

  // Filter
  const filtered = useMemo(() => {
    let result = orders;
    if (activeFilter !== 'ALL') {
      result = result.filter(o => o.status === activeFilter);
    }
    if (searchQuery.trim()) {
      const q = searchQuery.toLowerCase();
      result = result.filter(
        o =>
          o.title.toLowerCase().includes(q) ||
          o.clientName.toLowerCase().includes(q) ||
          o.id.includes(q)
      );
    }
    // Sort
    result = [...result].sort((a, b) => {
      let cmp = 0;
      switch (sortField) {
        case 'id':
          cmp = parseInt(a.id) - parseInt(b.id);
          break;
        case 'title':
          cmp = a.title.localeCompare(b.title);
          break;
        case 'amount':
          cmp = a.amount - b.amount;
          break;
        case 'createdAt':
          cmp = new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime();
          break;
        case 'status':
          cmp = a.status.localeCompare(b.status);
          break;
      }
      return sortDir === 'asc' ? cmp : -cmp;
    });
    return result;
  }, [orders, activeFilter, searchQuery, sortField, sortDir]);

  const handleSort = (field: SortField) => {
    if (sortField === field) {
      setSortDir(d => (d === 'asc' ? 'desc' : 'asc'));
    } else {
      setSortField(field);
      setSortDir('asc');
    }
  };

  // Status filter tabs
  const statusFilters: { key: string; label: string }[] = [
    { key: 'ALL', label: 'Все' },
    { key: 'NEW', label: 'Новый' },
    { key: 'IN_PRODUCTION', label: 'В производстве' },
    { key: 'ASSEMBLY', label: 'Сборка' },
    { key: 'SHIPPED', label: 'Доставка' },
    { key: 'COMPLETED', label: 'Выполнено' },
    { key: 'CANCELLED', label: 'Отменено' },
  ];

  return (
    <div className="flex-1 flex flex-col overflow-hidden bg-[#F5F6FA]">
      {/* Sub-header with filters */}
      <div className="bg-white border-b border-[#E2E8F0] px-4 py-3 shrink-0">
        {/* Search + actions row */}
        <div className="flex items-center gap-3 mb-3">
          <div className="flex items-center bg-[#F5F6FA] rounded-lg px-3 py-2 flex-1 max-w-md border border-transparent focus-within:border-[#2A5CAA]/30 focus-within:bg-white transition-all">
            <Search size={16} className="text-gray-400 mr-2 shrink-0" />
            <input
              type="text"
              placeholder="Поиск по названию, клиенту, ID..."
              value={searchQuery}
              onChange={e => setSearchQuery(e.target.value)}
              className="bg-transparent text-sm outline-none w-full text-gray-700 placeholder-gray-400"
            />
            {searchQuery && (
              <button onClick={() => setSearchQuery('')} className="text-gray-300 hover:text-gray-500">
                <X size={14} />
              </button>
            )}
          </div>

          <div className="flex items-center gap-2 ml-auto">
            <button
              onClick={() => setShowFilters(!showFilters)}
              className="flex items-center gap-1.5 px-3 py-2 text-xs font-medium text-gray-600 bg-[#F5F6FA] hover:bg-gray-100 rounded-lg transition-colors border border-[#E2E8F0]"
            >
              <Filter size={14} />
              Все фильтры
            </button>
            <button
              onClick={() => onNavigate('orders')}
              className="flex items-center gap-1.5 px-3 py-2 text-xs font-medium bg-[#2A5CAA] text-white hover:bg-[#1E4380] rounded-lg transition-colors"
            >
              <Plus size={14} />
              Добавить заказ
            </button>
          </div>
        </div>

        {/* Status filter tabs */}
        <div className="flex items-center gap-1 overflow-x-auto crm-scroll pb-0.5">
          {statusFilters.map(sf => {
            const count = statusCounts[sf.key] || 0;
            const isActive = activeFilter === sf.key;
            return (
              <button
                key={sf.key}
                onClick={() => setActiveFilter(sf.key)}
                className={`flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium whitespace-nowrap transition-all ${
                  isActive
                    ? 'bg-[#2A5CAA] text-white shadow-sm'
                    : 'text-gray-600 hover:bg-gray-100'
                }`}
              >
                {sf.label}
                <span className={`text-[10px] px-1.5 py-0.5 rounded-full ${
                  isActive ? 'bg-white/20 text-white' : 'bg-gray-100 text-gray-500'
                }`}>
                  {count}
                </span>
              </button>
            );
          })}
        </div>

        {/* Advanced filters (hidden by default) */}
        {showFilters && (
          <div className="mt-3 pt-3 border-t border-[#F1F5F9] flex items-center gap-3 animate-fade-in">
            <div className="flex items-center gap-2">
              <Calendar size={14} className="text-gray-400" />
              <input
                type="date"
                className="text-xs bg-[#F5F6FA] border border-[#E2E8F0] rounded-lg px-3 py-1.5 text-gray-600 outline-none"
              />
              <span className="text-gray-400 text-xs">—</span>
              <input
                type="date"
                className="text-xs bg-[#F5F6FA] border border-[#E2E8F0] rounded-lg px-3 py-1.5 text-gray-600 outline-none"
              />
            </div>
            <select className="text-xs bg-[#F5F6FA] border border-[#E2E8F0] rounded-lg px-3 py-1.5 text-gray-600 outline-none">
              <option>Все менеджеры</option>
              <option>Валентина Полевая</option>
              <option>Виктория Плетнева</option>
              <option>Сергей Коваленко</option>
            </select>
            <button className="text-xs text-[#2A5CAA] hover:text-[#1E4380] font-medium">
              Очистить
            </button>
          </div>
        )}
      </div>

      {/* Orders table */}
      <div className="flex-1 overflow-auto crm-scroll">
        <table className="w-full crm-table">
          <thead>
            <tr className="bg-[#F8F9FB]">
              <th className="w-10">
                <input type="checkbox" className="rounded border-gray-300" />
              </th>
              <th
                className="cursor-pointer select-none"
                onClick={() => handleSort('id')}
              >
                ID <ArrowUpDown size={12} className={`inline ml-1 ${sortField === 'id' ? 'text-[#2A5CAA]' : 'text-gray-300'}`} />
              </th>
              <th
                className="cursor-pointer select-none"
                onClick={() => handleSort('title')}
              >
                Название <ArrowUpDown size={12} className={`inline ml-1 ${sortField === 'title' ? 'text-[#2A5CAA]' : 'text-gray-300'}`} />
              </th>
              <th
                className="cursor-pointer select-none"
                onClick={() => handleSort('createdAt')}
              >
                Дата создания <ArrowUpDown size={12} className={`inline ml-1 ${sortField === 'createdAt' ? 'text-[#2A5CAA]' : 'text-gray-300'}`} />
              </th>
              <th>Статус</th>
              <th className="cursor-pointer select-none" onClick={() => handleSort('amount')}>
                Сумма заказа <ArrowUpDown size={12} className={`inline ml-1 ${sortField === 'amount' ? 'text-[#2A5CAA]' : 'text-gray-300'}`} />
              </th>
              <th>Себестоимость</th>
              <th>Прибыль</th>
              <th>Менеджер</th>
              <th>Оплата</th>
              <th className="w-10"></th>
            </tr>
          </thead>
          <tbody>
            {filtered.length === 0 ? (
              <tr>
                <td colSpan={11} className="text-center py-16 text-gray-400">
                  <div className="flex flex-col items-center gap-2">
                    <Search size={32} className="text-gray-300" />
                    <p className="text-sm">Заказы не найдены</p>
                  </div>
                </td>
              </tr>
            ) : (
              filtered.map((order) => {
                const profit = order.amount - order.plannedCost;
                const margin = order.amount > 0 ? ((profit / order.amount) * 100) : 0;
                return (
                  <tr
                    key={order.id}
                    onClick={() => onSelectOrder(order.id)}
                    className="group"
                  >
                    <td onClick={e => e.stopPropagation()}>
                      <input type="checkbox" className="rounded border-gray-300" />
                    </td>
                    <td>
                      <span className="text-xs font-mono text-[#2A5CAA] font-medium">#{order.id}</span>
                    </td>
                    <td>
                      <div className="font-medium text-gray-900 text-sm">{order.title}</div>
                      <div className="text-xs text-gray-400 mt-0.5">{order.clientName}</div>
                    </td>
                    <td className="text-xs text-gray-500 whitespace-nowrap">
                      {formatDateTime(order.createdAt)}
                    </td>
                    <td>
                      <span className={`status-badge ${STATUS_COLORS[order.status]}`}>
                        {STATUS_LABELS[order.status]}
                      </span>
                    </td>
                    <td>
                      <div className="font-semibold text-sm text-gray-900">
                        {formatUAH(order.amount)}
                      </div>
                      {order.isAmountManual && (
                        <span className="text-[10px] text-blue-500 font-medium">Вручную</span>
                      )}
                    </td>
                    <td className="text-sm text-gray-500">
                      {formatUAH(order.plannedCost)}
                    </td>
                    <td>
                      <span className={`text-sm font-semibold ${margin > 20 ? 'text-emerald-600' : margin > 10 ? 'text-amber-600' : 'text-red-500'}`}>
                        {formatUAH(profit)}
                      </span>
                      <div className={`text-[10px] ${margin > 20 ? 'text-emerald-500' : margin > 10 ? 'text-amber-500' : 'text-red-400'}`}>
                        {margin.toFixed(1)}%
                      </div>
                    </td>
                    <td>
                      <div className="flex items-center gap-2">
                        <div className="w-7 h-7 rounded-full bg-[#2A5CAA]/10 text-[#2A5CAA] flex items-center justify-center text-[10px] font-bold shrink-0">
                          {order.managerName.split(' ').map(n => n[0]).join('')}
                        </div>
                        <span className="text-xs text-gray-600 hidden lg:inline">{order.managerName}</span>
                      </div>
                    </td>
                    <td>
                      <span className={`status-badge ${PAYMENT_STATUS_COLORS[order.paymentStatus]}`}>
                        {PAYMENT_STATUS_LABELS[order.paymentStatus]}
                      </span>
                    </td>
                    <td onClick={e => e.stopPropagation()}>
                      <button className="p-1.5 rounded-md hover:bg-gray-100 transition-colors opacity-0 group-hover:opacity-100">
                        <MoreVertical size={14} className="text-gray-400" />
                      </button>
                    </td>
                  </tr>
                );
              })
            )}
          </tbody>
        </table>
      </div>

      {/* Footer with count */}
      <div className="bg-white border-t border-[#E2E8F0] px-4 py-2 flex items-center justify-between text-xs text-gray-500 shrink-0">
        <span>Показано {filtered.length} из {orders.length} заказов</span>
        <div className="flex items-center gap-1">
          <button className="px-3 py-1 rounded-md bg-[#2A5CAA] text-white">1</button>
          <button className="px-3 py-1 rounded-md hover:bg-gray-100">2</button>
          <button className="px-3 py-1 rounded-md hover:bg-gray-100">3</button>
        </div>
      </div>
    </div>
  );
}
