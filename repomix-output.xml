                  : 'bg-emerald-600 hover:bg-emerald-700'
              )}
            >
              <Plus className="w-4 h-4 mr-1.5" />
              {tr('save')}
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

    </div>
  );
}
