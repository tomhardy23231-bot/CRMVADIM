              </CardDescription>
            </div>
            
            {/* Сводка */}
            <div className="flex items-center gap-2 shrink-0 flex-wrap">
              {totalIncome > 0 && (
                <div className="flex items-center gap-1 bg-emerald-50 text-emerald-700 text-xs font-semibold px-2.5 py-1.5 rounded-lg border border-emerald-200">
