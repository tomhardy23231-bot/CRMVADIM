'use client';

import React from 'react';
import { formatUAH } from '@/lib/crm-utils';
import { MOCK_ORDERS } from '@/lib/mock-data';
import { TrendingUp, TrendingDown, Calendar } from 'lucide-react';

export default function PaymentCalendarPage() {
  // Generate week columns (6 weeks forward)
  const weeks = Array.from({ length: 6 }, (_, i) => {
    const start = new Date();
    start.setDate(start.getDate() - start.getDay() + 1 + i * 7);
    const end = new Date(start);
    end.setDate(end.getDate() + 6);
    const label = `${String(start.getDate()).padStart(2, '0')}.${String(start.getMonth() + 1).padStart(2, '0')} - ${String(end.getDate()).padStart(2, '0')}.${String(end.getMonth() + 1).padStart(2, '0')}`;
    return label;
  });

  // Active orders with budget items as rows
  const activeOrders = MOCK_ORDERS.filter(o => o.status !== 'CANCELLED' && o.status !== 'COMPLETED');

  return (
    <div className="flex-1 overflow-auto crm-scroll bg-[#F5F6FA]">
      <div className="p-4 space-y-4">
        <div className="flex items-center justify-between">
          <div className="flex items-center gap-2">
            <Calendar size={18} className="text-[#2A5CAA]" />
            <h2 className="text-lg font-bold text-gray-900">Платёжный календарь</h2>
          </div>
          <select className="text-xs bg-white border border-[#E2E8F0] rounded-lg px-3 py-1.5 text-gray-600 outline-none">
            <option>6 недель</option>
            <option>12 недель</option>
            <option>6 месяцев</option>
          </select>
        </div>

        {/* Legend */}
        <div className="flex items-center gap-4 text-xs text-gray-500">
          <div className="flex items-center gap-1.5">
            <div className="w-3 h-3 rounded bg-emerald-500" />
            <span>Доходы</span>
          </div>
          <div className="flex items-center gap-1.5">
            <div className="w-3 h-3 rounded bg-red-500" />
            <span>Расходы</span>
          </div>
          <div className="flex items-center gap-1.5">
            <div className="w-3 h-3 rounded bg-blue-500" />
            <span>Сальдо</span>
          </div>
        </div>

        {/* Calendar table */}
        <div className="bg-white rounded-xl border border-[#E2E8F0] overflow-hidden">
          <div className="overflow-x-auto">
            <table className="w-full min-w-[900px]">
              <thead>
                <tr className="bg-[#F8F9FB]">
                  <th className="sticky left-0 bg-[#F8F9FB] z-10 text-left px-4 py-3 text-[10px] font-semibold text-gray-500 uppercase tracking-wider border-b border-r border-[#E2E8F0] min-w-[200px]">
                    Заказ / Статья
                  </th>
                  {weeks.map(w => (
                    <th key={w} className="px-3 py-3 text-[10px] font-semibold text-gray-500 uppercase tracking-wider border-b border-[#E2E8F0] text-center whitespace-nowrap">
                      {w}
                    </th>
                  ))}
                  <th className="px-3 py-3 text-[10px] font-semibold text-gray-500 uppercase tracking-wider border-b border-[#E2E8F0] text-center bg-[#F0F7FF]">
                    Итого
                  </th>
                </tr>
              </thead>
              <tbody>
                {activeOrders.map(order => (
                  <React.Fragment key={order.id}>
                    {/* Order header row */}
                    <tr className="bg-[#FAFBFF]">
                      <td className="sticky left-0 bg-[#FAFBFF] z-10 px-4 py-2 border-b border-r border-[#E2E8F0]">
                        <span className="text-xs font-mono text-[#2A5CAA]">#{order.id}</span>
                        <span className="text-xs font-medium text-gray-900 ml-1">{order.title}</span>
                      </td>
                      {weeks.map(w => <td key={w} className="px-3 py-2 border-b border-[#E2E8F0] text-center" />)}
                      <td className="px-3 py-2 border-b border-[#E2E8F0] text-center bg-[#F0F7FF] font-semibold text-xs" />
                    </tr>
                    {/* Budget rows */}
                    {order.budgetItems.map(bi => {
                      const isIncome = bi.type === 'INCOME';
                      return (
                        <tr key={bi.id} className="hover:bg-[#F8FAFF] transition-colors">
                          <td className="sticky left-0 bg-white z-10 px-4 py-2 border-b border-r border-[#E2E8F0]">
                            <div className="flex items-center gap-2 pl-4">
                              <div className={`w-1.5 h-1.5 rounded-full ${isIncome ? 'bg-emerald-500' : 'bg-red-500'}`} />
                              <span className="text-xs text-gray-600">{bi.name}</span>
                            </div>
                          </td>
                          {weeks.map((w, wi) => {
                            // Mock: show amount in random week
                            const showAmount = wi === 2;
                            return (
                              <td key={w} className="px-3 py-2 border-b border-[#E2E8F0] text-center">
                                {showAmount ? (
                                  <span className={`text-xs font-medium ${isIncome ? 'text-emerald-600' : 'text-red-500'}`}>
                                    {formatUAH(bi.plan)}
                                  </span>
                                ) : (
                                  <span className="text-xs text-gray-300">—</span>
                                )}
                              </td>
                            );
                          })}
                          <td className={`px-3 py-2 border-b border-[#E2E8F0] text-center bg-[#F0F7FF] text-xs font-semibold ${isIncome ? 'text-emerald-600' : 'text-red-500'}`}>
                            {formatUAH(bi.plan)}
                          </td>
                        </tr>
                      );
                    })}
                  </React.Fragment>
                ))}
              </tbody>
              {/* Totals row */}
              <tfoot>
                <tr className="bg-[#F8F9FB] font-bold">
                  <td className="sticky left-0 bg-[#F8F9FB] z-10 px-4 py-3 border-t-2 border-r border-[#E2E8F0] text-xs text-gray-900">
                    ИТОГО
                  </td>
                  {weeks.map(w => (
                    <td key={w} className="px-3 py-3 border-t-2 border-[#E2E8F0] text-center text-xs text-[#2A5CAA]">
                      {formatUAH(Math.floor(Math.random() * 50000 + 10000))}
                    </td>
                  ))}
                  <td className="px-3 py-3 border-t-2 border-[#E2E8F0] text-center bg-[#E8F0FE] text-xs text-[#2A5CAA]">
                    {formatUAH(MOCK_ORDERS.reduce((s, o) => s + o.amount, 0))}
                  </td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>
      </div>
    </div>
  );
}
