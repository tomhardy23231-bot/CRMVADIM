// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Order {
  id                    String   @id @default(cuid()) // internal ID
  externalId            String?  // Can store 1C Contract/Tender ID
  name                  String
  status                String   @default("Новый") // 'Новый' | 'В производстве' | 'Сборка' | 'Отгружен'
  orderAmount           Float    @default(0)
  isAmountManual        Boolean  @default(false)
  plannedCost           Float    @default(0)
  deadline              String   // ISO limit
  productionStart       String
  assemblyStart         String
  shippingStart         String
  expectedPaymentDate   String?  // Ожидаемая дата оплаты клиентом (ISO)
  
  isProductionStarted Boolean  @default(false)
  isAssemblyStarted   Boolean  @default(false)
  isShipped           Boolean  @default(false)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  isArchived          Boolean  @default(false)

  budgetItems         BudgetItem[]
  specItems           SpecItem[]
  payments            Payment1C[]
}

model BudgetItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  name        String
  plan        Float    @default(0)
  fact        Float    @default(0)
  isIncome    Boolean  @default(false)
  hasTranches Boolean  @default(false)

  tranches    Tranche[]
  payments    Payment1C[] // Привязанные факты из 1С

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tranche {
  id           String     @id @default(cuid())
  budgetItemId String
  budgetItem   BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
  
  amount       Float      @default(0)
  month        String     // 'YYYY-Wxx::DD.MM-DD.MM' (legacy week format)
  plannedDate  String?    // ISO date 'YYYY-MM-DD' (new precise date)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model SpecItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  material     String
  unit         String
  quantity     Float    @default(1)
  pricePerUnit Float    @default(0)
  total        Float    @default(0)
  cost         Float?   // Себестоимость

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Payment1C {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  date         String   // Дата операции
  document     String   // Строковое представление документа 1С (РКО и тд)
  article      String?  // Статья ДДС или комментарий (из 1С)
  income       Float    @default(0)
  expense      Float    @default(0)

  budgetItemId String?  // Привязка к конкретной плановой статье бюджета СРМ
  budgetItem   BudgetItem? @relation(fields: [budgetItemId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================================
// Роли пользователей
// ============================================================
enum UserRole {
  ADMIN     // Полный доступ + управление аккаунтами
  MANAGER   // Менеджер — работа с заказами
  WORKER    // Рабочий — минимальный доступ
}

// ============================================================
// Пользователь системы
// ============================================================
model User {
  id          String   @id @default(cuid())
  login       String   @unique
  password    String                       // bcrypt hash
  firstName   String
  lastName    String
  role        UserRole @default(MANAGER)
  isActive    Boolean  @default(true)

  // JSON-объект с разрешениями (canViewProfit, canViewBudget, etc.)
  permissions Json     @default("{}")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs        AuditLog[]
}

// ============================================================
// Журнал действий (Audit Log)
// ============================================================
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  action    String   // "order.create", "user.login", "budget.update" ...
  entity    String?  // "order", "user", "budgetItem"
  entityId  String?  // ID затронутой сущности
  details   Json?    // { oldValue, newValue, description }

  createdAt DateTime @default(now())
}